# Optional: override model names
GEN_MODEL_GRANITE=granite4.1:3b
GEN_MODEL_QWEN=qwen3.5:4b
EMBED_MODEL=qwen3-embedding:4b

# Optional: Hugging Face cache
HF_HOME=/tmp/hf-home

# Optional: Neo4j local demo credentials
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password

# Optional: enable model-assisted SQL->Cypher refinement
ENABLE_CYPHER_REFINEMENT=false
